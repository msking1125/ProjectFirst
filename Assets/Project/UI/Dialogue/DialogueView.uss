/* ?쒓? ?고듃 ?????*/
.unity-label,
.unity-button,
.unity-toggle {
    -unity-font-definition: url("project://database/Assets/Project/Fonts/HeirofLightBold SDF_2.asset");
}

.dialogue-root {
    width: 100%;
    height: 100%;
    position: relative;
}

/* 諛곌꼍 ?대?吏 */
.bg-image {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-size: cover;
    background-position: center;
}

/* 罹먮┃??怨듯넻 */
.character {
    position: absolute;
    bottom: 15%;
    width: 380px;
    height: 500px;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: bottom center;
}

.character-left {
    left: 5%;
}

.character-right {
    right: 5%;
}

.character-center {
    left: 50%;
    translate: -50% 0;
}

/* ?섎젅?댁뀡 諛뺤뒪 (以묒븰 ?섑룊 諛? */
.narration-box {
    position: absolute;
    top: 40%;
    left: 10%;
    right: 10%;
    padding: 24px 32px;
    background-color: rgba(0, 0, 0, 0.75);
    border-radius: 8px;
    align-items: center;
    justify-content: center;
}

.narration-text {
    font-size: 20px;
    color: #e0e0e0;
    white-space: normal;
    -unity-text-align: middle-center;
}

/* ???諛뺤뒪 (?섎떒) */
.dialogue-box {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 25%;
    background-color: rgba(0, 0, 0, 0.85);
    padding: 20px 28px;
    flex-direction: column;
}

.speaker-name-label {
    font-size: 22px;
    color: #ffd700;
    margin-bottom: 8px;
    -unity-font-style: bold;
}

.dialogue-text {
    font-size: 18px;
    color: #ffffff;
    white-space: normal;
    -unity-text-align: upper-left;
    flex-grow: 1;
}

/* ?좏깮吏 ?⑤꼸 */
.choice-panel {
    position: absolute;
    top: 35%;
    left: 50%;
    translate: -50% 0;
    flex-direction: column;
    align-items: center;
}

.choice-btn {
    width: 400px;
    height: 56px;
    font-size: 20px;
    margin-bottom: 16px;
    color: #ffffff;
    background-color: rgba(40, 40, 80, 0.9);
    border-color: rgba(200, 200, 255, 0.4);
    border-width: 1px;
    border-radius: 8px;
    -unity-text-align: middle-center;
}

.choice-btn:hover {
    background-color: rgba(60, 60, 120, 0.95);
    border-color: rgba(200, 200, 255, 0.8);
}

/* 而⑦듃濡?踰꾪듉 (?곗긽?? */
.control-row {
    position: absolute;
    top: 16px;
    right: 16px;
    flex-direction: row;
}

.control-btn {
    width: 72px;
    height: 36px;
    font-size: 14px;
    margin-left: 8px;
    color: #cccccc;
    background-color: rgba(0, 0, 0, 0.5);
    border-color: rgba(200, 200, 200, 0.3);
    border-width: 1px;
    border-radius: 6px;
    -unity-text-align: middle-center;
}

.control-btn:hover {
    background-color: rgba(0, 0, 0, 0.7);
    color: #ffffff;
}

.auto-active {
    background-color: rgba(80, 160, 80, 0.7);
    color: #ffffff;
    border-color: rgba(100, 200, 100, 0.6);
}

/* ?ㅼ쓬 ?붿궡??(?고븯?? */
.next-arrow {
    position: absolute;
    bottom: 4%;
    right: 28px;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
}

.next-arrow-icon {
    font-size: 20px;
    color: #ffffff;
}

/* ?ㅽ궢 ?뺤씤 ?앹뾽 */
.confirm-popup {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.6);
    align-items: center;
    justify-content: center;
}

.confirm-popup-box {
    width: 360px;
    padding: 28px 24px;
    background-color: rgba(20, 20, 40, 0.95);
    border-radius: 12px;
    border-width: 1px;
    border-color: rgba(200, 200, 255, 0.3);
    align-items: center;
}

.confirm-popup-text {
    font-size: 20px;
    color: #ffffff;
    margin-bottom: 24px;
    -unity-text-align: middle-center;
}

.confirm-popup-buttons {
    flex-direction: row;
}

.confirm-btn {
    width: 120px;
    height: 44px;
    font-size: 18px;
    border-radius: 8px;
    -unity-text-align: middle-center;
    margin-left: 8px;
    margin-right: 8px;
}

.confirm-btn-yes {
    color: #ffffff;
    background-color: rgba(80, 140, 200, 0.9);
    border-color: rgba(100, 160, 220, 0.6);
    border-width: 1px;
}

.confirm-btn-no {
    color: #cccccc;
    background-color: rgba(60, 60, 60, 0.9);
    border-color: rgba(120, 120, 120, 0.4);
    border-width: 1px;
}
