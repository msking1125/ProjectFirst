<?xml version="1.0" encoding="utf-8"?>
<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <ui:Style src="project://database/Assets/Project/UI/Mailbox/MailboxView.uss" />

    <!-- ąwąw ?? ?? ąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąw -->
    <ui:VisualElement name="mailbox-panel" class="mailbox-panel" style="display: none;">

        <!-- ąwąw ?? ?? ąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąw -->
        <ui:VisualElement name="panel-header" class="panel-header">
            <ui:Label name="title-label" class="title-label" text="???" />
            <ui:Button name="close-btn" class="close-btn" text="?" />
        </ui:VisualElement>

        <!-- ąwąw ? ? ąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąw -->
        <ui:VisualElement name="tab-row" class="tab-row">
            <ui:Button name="unclaimed-tab-btn" class="tab-btn tab-active" text="???">
                <ui:Label name="unclaimed-badge" class="unclaimed-badge" text="0" />
            </ui:Button>
            <ui:Button name="claimed-tab-btn" class="tab-btn" text="????" />
        </ui:VisualElement>

        <!-- ąwąw ?? ??? (ListView) ąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąw -->
        <ui:ListView name="mail-list" class="mail-list" />

        <!-- ąwąw ? ?? ?? ąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąw -->
        <ui:VisualElement name="empty-state-view" class="empty-state-view" style="display: none;">
            <ui:Label name="empty-label" class="empty-label" text="?? ??? ????" />
        </ui:VisualElement>

        <!-- ąwąw ??? ?? (?? ????) ąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąw -->
        <ui:VisualElement name="detail-panel" class="detail-panel" style="display: none;">
            <ui:Label name="detail-title" class="detail-title" text="" />

            <ui:VisualElement class="detail-meta-row">
                <ui:Label name="detail-sender" class="detail-sender" text="" />
                <ui:Label name="detail-date" class="detail-date" text="" />
            </ui:VisualElement>

            <ui:VisualElement class="detail-divider" />

            <ui:Label name="detail-body" class="detail-body" text="" />

            <ui:Label class="detail-rewards-title" text="?? ??" />
            <ui:VisualElement name="detail-rewards-row" class="detail-rewards-row" />

            <ui:Button name="detail-claim-btn" class="detail-claim-btn" text="?? ??" />
        </ui:VisualElement>

        <!-- ąwąw ?? ?? ? ąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąw -->
        <ui:VisualElement name="bottom-action-bar" class="bottom-action-bar">
            <ui:Button name="claim-all-btn" class="action-btn claim-all-btn" text="?? ??" />
            <ui:Button name="delete-read-btn" class="action-btn delete-read-btn" text="?? ?? ??" />
        </ui:VisualElement>

        <!-- ąwąw ?? ?? ???? (?? ??) ąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąw -->
        <ui:VisualElement name="reward-overlay" class="reward-overlay" style="display: none;">
            <ui:Label name="reward-title-label" class="reward-title-label" text="?? ??!" />
            <ui:VisualElement name="reward-cards-container" class="reward-cards-container" />
            <ui:Label name="reward-touch-label" class="reward-touch-label" text="TOUCH TO CONTINUE" />
        </ui:VisualElement>

        <!-- ąwąw ?? ?? (?? ??) ąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąwąw -->
        <ui:VisualElement name="confirm-overlay" class="confirm-overlay" style="display: none;">
            <ui:VisualElement name="confirm-dialog" class="confirm-dialog">
                <ui:Label name="confirm-message" class="confirm-message" text="" />
                <ui:VisualElement name="confirm-buttons" class="confirm-buttons">
                    <ui:Button name="confirm-yes-btn" class="confirm-btn confirm-yes" text="??" />
                    <ui:Button name="confirm-no-btn" class="confirm-btn confirm-no" text="??" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>

    </ui:VisualElement>
    <!-- end mailbox-panel -->

</ui:UXML>
